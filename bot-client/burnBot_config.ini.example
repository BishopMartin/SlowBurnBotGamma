# Copy to burnBot_config.ini (gitignored) and adjust paths.
# On first run, the bot writes this file automatically from the activation token.
# Edit manually only if you need to override defaults.

[bot_settings]
client_id = 1
system_type = windows
bot_debug = FALSE

[api]
api_url = https://slowburnbotgamma-production.up.railway.app

[api_credentials]
# Optional: store dashboard email/password to skip manual entry at startup.
# If set, the bot can re-call /auth/jwt/login when the saved JWT expires (long runs).
# Leave blank to be prompted interactively (you must restart manually after token expiry).
email =
password =

[browser-config]
# Windows defaults (written automatically on activation for windows builds)
chrome_version = 143
chrome_path = PortableChrome\chrome.exe
chrome_user_data_dir_base = PortableChrome
system_user_agent = Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36
add_argument =

# Linux / Docker defaults (written automatically on activation for linux builds)
# chrome_version =
# chrome_path = /usr/bin/google-chrome
# chrome_user_data_dir_base =
# system_user_agent = Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36
# add_argument =

[browser-session]
headless = False
detach = False
close_browser_after_session = False
close_browser_after_exit = False
bot_idle_delay = 5

# Linux / Docker defaults
# headless = True
# detach = False
# close_browser_after_session = False
# close_browser_after_exit = False
# bot_idle_delay = 5
