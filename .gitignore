# Spreadsheet exports from Google Drive often contain passwords, API keys, and PII.
# Do not commit live workbooks. Use docs/sheets-schema.md for structure-only reference.
*.xlsx
*.xls

# Google Sheets shortcut stubs (cloud-only; not useful in git)
*.gsheet

# Bot client lives in its own repo (BishopMartin/SlowBurnBot-BotClient)
bot-client/

# Local bot state / secrets (common in sibling Beta tree; mirror here if copied)
burnBot_runs.json
*-slowburnbot-*.json
*credentials*.json
*service-account*.json

# Python
__pycache__/
*.py[cod]
*.pyo

# Next.js
frontend/.next/
frontend/node_modules/
frontend/.env.local

# Local secrets (Railway token, etc.)
.env
.env.*
!.env.example
