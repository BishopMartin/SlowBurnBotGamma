# Spreadsheet exports from Google Drive often contain passwords, API keys, and PII.
# Do not commit live workbooks. Use docs/sheets-schema.md for structure-only reference.
*.xlsx
*.xls

# Local Claude Code settings (may contain tokens)
.claude/settings.local.json

# Google Sheets shortcut stubs (cloud-only; not useful in git)
*.gsheet

# Bot client — source tracked here; exclude runtime/local artifacts
bot-client/burnBot_config.ini
bot-client/burnBot_runs.json
bot-client/.venv/
bot-client/ChromeUserData/
bot-client/PortableChrome/
bot-client/dist/
bot-client/build/
bot-client/*.spec.bak

# Local scratch / planning files
plan_*.md
client-output-example.txt
danger-list.json
git

# Local bot state / secrets (common in sibling Beta tree; mirror here if copied)
burnBot_runs.json
*-slowburnbot-*.json
*credentials*.json
*service-account*.json

# Python
__pycache__/
*.py[cod]
*.pyo

# Next.js
frontend/.next/
frontend/node_modules/
frontend/.env.local

# Local secrets (Railway token, etc.)
.env
.env.*
!.env.example
