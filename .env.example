# Copy to .env and fill in values. Never commit .env.

# Database (Railway injects DATABASE_URL automatically in production)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/railway

# Auth
SECRET_KEY=replace-with-strong-random-hex

# App
ENVIRONMENT=development

# Stripe (add when ready for Phase 3)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS (add Next.js URL when deployed — Phase 4)
CORS_ORIGINS=["http://localhost:3000"]
