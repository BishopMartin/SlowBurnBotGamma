# Copy to .env and fill in values. Never commit .env.

# Database (Railway injects DATABASE_URL automatically in production)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/railway

# Auth
SECRET_KEY=replace-with-strong-random-hex

# Optional: dedicated key for encrypting stored IG passwords (app/crypto.py),
# kept separate from SECRET_KEY so a leak of one doesn't compromise the other.
# Falls back to SECRET_KEY when unset. If you set this on an existing install
# with stored credentials, run scripts/rotate_credential_encryption_key.py
# first to re-encrypt them under the new key.
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-different-strong-random-hex

# App
ENVIRONMENT=development
PUBLIC_API_URL=https://slowburnbotgamma-production.up.railway.app

# Admin credentials (used by scripts/release-bot-client.sh to sync bot version after tag push)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-admin-password

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CRAWL=price_...
STRIPE_PRICE_WALK=price_...
STRIPE_PRICE_RUN=price_...

# GitHub (for release artifact management)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=BishopMartin/SlowBurnBotGamma
GHCR_NAMESPACE=bishopmartin

# Object storage (Railway bucket or S3-compatible)
BUCKET_ENDPOINT_URL=https://...
BUCKET_NAME=slowburn-releases
BUCKET_ACCESS_KEY_ID=...
BUCKET_SECRET_ACCESS_KEY=...
BUCKET_REGION=us-east-1
