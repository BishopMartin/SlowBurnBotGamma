# Copy to .env and fill in (never commit .env).
#
# --- Auth option A: CLI login (interactive; run in YOUR terminal, not agent-only) ---
#   cd SlowBurnBotGamma
#   npx @railway/cli@latest login
#   (opens browser; completes OAuth; stores token for your user profile)
#   npx @railway/cli@latest link -p 7ea1c94f-861d-49d6-a428-6771c62ce371
#
# --- Auth option B: API token (CI / scripts / when login cannot run) ---
#   Create: https://railway.com/account/tokens
#   Then either:
#     setx RAILWAY_TOKEN "railway_..."   # new shells only; or in current session:
#     $env:RAILWAY_TOKEN = "railway_..."
#   Or put RAILWAY_TOKEN in .env and load before .\scripts\railway-deploy.ps1
#
RAILWAY_TOKEN=
# Optional: defaults to SlowBurnBotGamma project if unset
RAILWAY_PROJECT_ID=7ea1c94f-861d-49d6-a428-6771c62ce371
